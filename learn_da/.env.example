APP_NAME=Learn DA Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
API_PREFIX=/api
API_VERSION=v1

DATABASE_URL=sqlite+aiosqlite:///./learn_da.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=True
DB_ECHO=False

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=False
CORS_ALLOW_ALL_ORIGINS=False

RATE_LIMIT_ENABLED=True
RATE_LIMIT_GLOBAL_IP=200/minute
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AGENT_CHAT=20/minute
RATE_LIMIT_PLAYGROUND_EXECUTE=10/minute

REDIS_ENABLED=False
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_CACHE_PREFIX=learn-da

LLM_API_KEY=your_llm_api_key
LLM_BASE_URL=https://api.modelverse.cn/v1
LLM_MODEL=deepseek-ai/DeepSeek-V3.2
OPENAI_API_KEY=your_llm_api_key
OPENAI_BASE_URL=https://api.modelverse.cn/v1
OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2
OPENAI_MAX_TURNS=3
LEARN_DA_EMBEDDING_PROVIDER=openai_compatible
LEARN_DA_EMBEDDING_API_KEY=your_embedding_api_key
LEARN_DA_EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LEARN_DA_EMBEDDING_MODEL=doubao-embedding-vision
LEARN_DA_EMBEDDING_DIM=

SANDBOX_DOCKER_ENABLED=False
SANDBOX_DOCKER_IMAGE=polars-duckdb-sandbox:latest
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEMORY_LIMIT_MB=256
SANDBOX_CPU_QUOTA=50000
SANDBOX_USE_MOCK_WHEN_DISABLED=True

ENABLED_APP_MODULES=learning,playground,agent
